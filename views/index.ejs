<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Job Finder</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar">
        <div class="navbar-container">
            <div class="logo">Job Finder</div>
            <ul class="nav-menu">
                <li><a href="/" class="active">Dashboard</a></li>
                <li><a href="/jobs">Jobs</a></li>
                <li><a href="/companies">Companies</a></li>
            </ul>
        </div>
    </nav>

    <main class="container">
        <section class="hero">
            <h1>Job Search Dashboard</h1>
            <p>Track scraped jobs, matched roles, and recent search runs in one clean view.</p>
        </section>

        <section class="scraped-companies">
            <h2><span></span>Active Companies</h2>
            <div id="scraping-grid" class="scraped-grid">
                <div class="loading-spinner">Loading companies...</div>
            </div>
        </section>

        <section class="dashboard-grid">
            <div class="card">
                <h2>Quick Stats</h2>
                <div id="stats-content" class="loading">Loading...</div>
            </div>

            <div class="card">
                <h2>Job Search</h2>
                <p class="muted">Manually trigger a fresh scrape and profile match.</p>
                <button class="btn btn-primary" onclick="runJobSearch(event)">Run Job Search</button>
            </div>

            <div class="card">
                <h2>Clear Raw Jobs</h2>
                <p class="muted">Remove raw scraped jobs when you want a cleaner restart.</p>
                <button class="btn btn-secondary" onclick="deleteRawJobs(event)">Clear Raw Jobs</button>
            </div>

            <div class="card">
                <h2>Recent Activity</h2>
                <div id="logs-content" class="loading">Loading...</div>
            </div>
        </section>

        <section class="page-section">
            <div class="section-heading">
                <h2>Jobs By Company</h2>
                <p>Matched roles are separated from scraped roles that did not pass the profile filter.</p>
            </div>
            <div id="company-jobs-content" class="loading">Loading jobs...</div>
        </section>
    </main>

    <footer class="footer">
        <p>&copy; 2026 Job Finder. Find your dream job easily.</p>
    </footer>

    <script src="/js/main.js"></script>
    <script src="/js/dashboard.js"></script>
</body>
</html>
