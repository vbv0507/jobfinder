<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jobs - Job Finder</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar">
        <div class="navbar-container">
            <div class="logo">Job Finder</div>
            <ul class="nav-menu">
                <li><a href="/">Dashboard</a></li>
                <li><a href="/jobs" class="active">Jobs</a></li>
                <li><a href="/companies">Companies</a></li>
            </ul>
        </div>
    </nav>

    <main class="container">
        <section class="hero">
            <h1>Job Opportunities</h1>
            <p>Matched fresher-friendly jobs grouped by company.</p>
        </section>

        <% if (Object.keys(jobs).length === 0) { %>
            <div class="empty-state">
                <p>No matched jobs found yet. Run a search to check the latest fresher-friendly roles.</p>
            </div>
        <% } else { %>
            <% Object.entries(jobs).forEach(([company, sections]) => { %>
                <section class="company-section">
                    <div class="company-name">
                        <span class="badge"><%= company %></span>
                        <small><%= sections.matched?.length || 0 %> matched jobs</small>
                    </div>

                    <% if (sections.matched && sections.matched.length > 0) { %>
                        <div class="subsection matched-section">
                            <h3 class="subsection-title">Matched Jobs (<%= sections.matched.length %>)</h3>
                            <div class="jobs-grid">
                                <% sections.matched.forEach(job => { %>
                                    <article class="job-card matched">
                                        <div class="job-header">
                                            <h3><%= job.role %></h3>
                                            <span class="score"><%= job.score %></span>
                                        </div>

                                        <div class="job-details">
                                            <p><strong>Location:</strong> <%= job.location %></p>
                                            <p><strong>Match:</strong> <%= job.roleMatch || 'Profile aligned' %></p>
                                        </div>

                                        <div class="job-footer">
                                            <small>AI selected</small>
                                            <a href="<%= job.applyLink %>" target="_blank" class="apply-btn">Apply</a>
                                        </div>
                                    </article>
                                <% }); %>
                            </div>
                        </div>
                    <% } %>
                </section>
            <% }); %>
        <% } %>
    </main>

    <footer class="footer">
        <p>&copy; 2026 Job Finder. Find your dream job easily.</p>
    </footer>
</body>
</html>
