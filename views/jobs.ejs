<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jobs - Job Finder</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar">
        <div class="navbar-container">
            <div class="logo">💼 Job Finder</div>
            <ul class="nav-menu">
                <li><a href="/">Dashboard</a></li>
                <li><a href="/jobs" class="active">Jobs</a></li>
                <li><a href="/companies">Companies</a></li>
            </ul>
        </div>
    </nav>

    <div class="container">
        <section class="hero">
            <h1>Job Opportunities</h1>
            <p>Matched jobs from Visa & LG</p>
        </section>

        <% if (Object.keys(jobs).length === 0) { %>
            <div class="empty-state">
                <p>No jobs found. Check back soon!</p>
            </div>
        <% } else { %>
            <% Object.entries(jobs).forEach(([company, sections]) => { %>
                <div class="company-section">
                    <h2 class="company-name">
                        <span class="badge"><%= company %></span>
                        <small><%= (sections.matched?.length || 0) + (sections.raw?.length || 0) %> jobs</small>
                    </h2>

                    <!-- MATCHED JOBS SECTION -->
                    <% if (sections.matched && sections.matched.length > 0) { %>
                        <div class="subsection matched-section">
                            <h3 class="subsection-title">✅ Matched Jobs (<%= sections.matched.length %>)</h3>
                            <div class="jobs-grid">
                                <% sections.matched.forEach(job => { %>
                                    <div class="job-card matched">
                                        <div class="job-header">
                                            <h3><%= job.role %></h3>
                                            <span class="score">Score: <%= job.score %></span>
                                        </div>
                                        
                                        <div class="job-details">
                                            <p><strong>📍 Location:</strong> <%= job.location %></p>
                                            <p><strong>💼 Match:</strong> <%= job.roleMatch %></p>
                                        </div>

                                        <div class="job-footer">
                                            <small>✨ AI Selected</small>
                                            <a href="<%= job.applyLink %>" target="_blank" class="apply-btn">Apply</a>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    <% } %>

                    <!-- RAW JOBS SECTION (Not Matched) -->
                    <% if (sections.raw && sections.raw.length > 0) { %>
                        <div class="subsection raw-section">
                            <h3 class="subsection-title">📋 Other Opportunities (<%= sections.raw.length %>)</h3>
                            <div class="jobs-grid">
                                <% sections.raw.forEach(job => { %>
                                    <div class="job-card raw">
                                        <div class="job-header">
                                            <h3><%= job.title %></h3>
                                            <span class="badge-gray">Raw</span>
                                        </div>
                                        
                                        <div class="job-details">
                                            <p><strong>📍 Location:</strong> <%= job.location %></p>
                                            <p><strong>💼 Type:</strong> <%= job.employmentType %></p>
                                            <p><strong>📌 Experience:</strong> <%= job.experience || 'Not specified' %></p>
                                        </div>

                                        <div class="job-footer">
                                            <% if (job.postedAt) { %>
                                                <small>Posted: <%= new Date(job.postedAt).toLocaleDateString() %></small>
                                            <% } %>
                                            <a href="<%= job.applyLink %>" target="_blank" class="apply-btn">Apply</a>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    <% } %>
                </div>
            <% }); %>
        <% } %>
    </div>

    <footer class="footer">
        <p>&copy; 2026 Job Finder. Find your dream job easily.</p>
    </footer>
</body>
</html>
