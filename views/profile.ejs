<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile - Job Finder</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar">
        <div class="navbar-container">
            <div class="logo">Job Finder</div>
            <ul class="nav-menu">
                <li><a href="/">Dashboard</a></li>
                <li><a href="/jobs">Jobs</a></li>
                <li><a href="/companies">Companies</a></li>
                <li><a href="/profile" class="active">Profile</a></li>
            </ul>
        </div>
    </nav>

    <main class="container">
        <section class="hero">
            <h1>Your Profile</h1>
            <p>Set your preferences to get matched with relevant jobs.</p>
        </section>

        <section class="form-section">
            <div class="form-card">
                <h2>Profile Information</h2>
                <form id="profile-form">
                    <div class="form-group">
                        <label for="name">Full Name</label>
                        <input type="text" id="name" placeholder="John Doe">
                    </div>

                    <div class="form-group">
                        <label for="graduation-year">Graduation Year</label>
                        <input type="number" id="graduation-year" placeholder="2026" min="1950" max="2100">
                    </div>

                    <div class="form-group">
                        <label for="skills">Skills (comma-separated)</label>
                        <textarea id="skills" placeholder="JavaScript, React, Node.js, MongoDB"></textarea>
                    </div>

                    <div class="form-group">
                        <label for="preferred-roles">Preferred Roles (comma-separated)</label>
                        <textarea id="preferred-roles" placeholder="Full Stack Developer, Backend Engineer"></textarea>
                    </div>

                    <div class="form-group">
                        <label for="preferred-locations">Preferred Locations (comma-separated)</label>
                        <textarea id="preferred-locations" placeholder="Remote, Bangalore, Hyderabad"></textarea>
                    </div>

                    <div class="form-group">
                        <label for="projects">Projects (comma-separated)</label>
                        <textarea id="projects" placeholder="Job Finder App, Portfolio Website"></textarea>
                    </div>

                    <div class="form-group">
                        <label for="career-preferences">Career Preferences (comma-separated)</label>
                        <textarea id="career-preferences" placeholder="Product Company, Startups, Remote-first"></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary">Save Profile</button>
                </form>
            </div>

            <div id="profile-display" class="profile-card" style="display: none;">
                <h2>Your Profile</h2>
                <div id="profile-info"></div>
                <button class="btn btn-secondary" onclick="editProfile()">Edit Profile</button>
            </div>
        </section>
    </main>

    <footer class="footer">
        <p>&copy; 2026 Job Finder. Find your dream job easily.</p>
    </footer>

    <script src="/js/main.js"></script>
    <script src="/js/profile.js"></script>
</body>
</html>
