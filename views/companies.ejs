<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Companies - Job Finder</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar">
        <div class="navbar-container">
            <div class="logo">Job Finder</div>
            <ul class="nav-menu">
                <li><a href="/">Dashboard</a></li>
                <li><a href="/jobs">Jobs</a></li>
                <li><a href="/companies" class="active">Companies</a></li>
            </ul>
        </div>
    </nav>

    <main class="container">
        <section class="hero">
            <h1>Companies</h1>
            <p>Manage the companies used by your scraper.</p>
        </section>

        <section class="scraped-companies">
            <h2><span></span>Currently Scraping From</h2>
            <div id="scraping-grid" class="scraped-grid">
                <div class="loading-spinner">Loading companies...</div>
            </div>
        </section>

        <section class="page-section">
            <div class="section-heading">
                <h2>Configured Companies</h2>
                <p>These companies are stored in MongoDB and used during each search run.</p>
            </div>
            <div id="companies-content" class="companies-list">
                <div class="loading-spinner">Loading companies...</div>
            </div>
        </section>
    </main>

    <footer class="footer">
        <p>&copy; 2026 Job Finder. Find your dream job easily.</p>
    </footer>

    <script src="/js/main.js"></script>
    <script src="/js/companies.js"></script>
</body>
</html>
